msgstr "Index bloku je mimo rozsah."

#: includes/class-block-crud.php:501
#: includes/class-block-crud.php:662
#. translators: %s: pattern name
#, php-format
msgid ""
"Removing synced pattern reference \"%s\" from this page. The pattern itself "
"is not deleted."
msgstr ""
"Odebírám synchronizovanou referenci vzoru „%s“ z této stránky. Vzor sám "
"není smazán."

#: includes/class-block-crud.php:581
msgid "range.start must be >= 0."
msgstr "range.start musí být >= 0."

#: includes/class-block-crud.php:606
