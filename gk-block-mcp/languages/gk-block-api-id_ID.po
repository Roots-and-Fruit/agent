msgstr "Host URL \"%1$s\" mengarah ke IPv4 yang dipesan atau pribadi (%2$s)."

#: includes/class-media-manager.php:462
#. translators: 1: IPv6 address, 2: hostname
#, php-format
msgid "Could not validate IPv6 \"%1$s\" for \"%2$s\"."
msgstr "Tidak dapat memvalidasi IPv6 \"%1$s\" untuk \"%2$s\"."

#: includes/class-media-manager.php:475
#. translators: 1: hostname, 2: IPv6 address, 3: CIDR
#, php-format
msgid "URL host \"%1$s\" resolves to a reserved or private IPv6 (%2$s, in %3$s)."
msgstr ""
"Host URL \"%1$s\" mengarah ke IPv6 yang dipesan atau pribadi (%2$s, dalam "
"%3$s)."

#: includes/class-post-manager.php:48
msgid "A non-empty \"title\" is required."
msgstr "\"title\" yang tidak kosong diperlukan."

#: includes/class-post-manager.php:57
#. translators: %s: post type slug
#, php-format
msgid "Post type \"%s\" is not allowed."
msgstr "Tipe pos \"%s\" tidak diperbolehkan."

#: includes/class-post-manager.php:69
msgid "Sorry, you are not allowed to create posts of this type."
msgstr "Maaf, Anda tidak diperbolehkan membuat pos tipe ini."

#: includes/class-post-manager.php:78
#. translators: %s: status slug
#, php-format
msgid ""
"Status \"%s\" is not allowed on create. Use update_post for trash "
"transitions."
msgstr ""
"Status \"%s\" tidak diperbolehkan saat membuat. Gunakan update_post untuk "
"transisi tempat sampah."

#: includes/class-post-manager.php:90
#: includes/class-post-manager.php:309
msgid "You cannot publish posts of this type."
msgstr "Anda tidak dapat menerbitkan pos tipe ini."

#: includes/class-post-manager.php:106
msgid "\"content\" and \"blocks\" are mutually exclusive."
msgstr "\"content\" dan \"blocks\" saling eksklusif."

#: includes/class-post-manager.php:169
#: includes/class-post-manager.php:412
msgid "You cannot assign authorship to other users."
msgstr "Anda tidak dapat menetapkan penulis kepada pengguna lain."

#: includes/class-post-manager.php:181
#: includes/class-post-manager.php:281
msgid "featured_media is not a valid image attachment."
msgstr "featured_media bukan lampiran gambar yang valid."

#: includes/class-post-manager.php:198
msgid "wp_insert_post returned a non-positive ID."
msgstr "wp_insert_post mengembalikan ID yang tidak positif."

#: includes/class-post-manager.php:254
#. translators: %d: post ID
#, php-format
msgid "Post %d does not exist."
msgstr "Posting %d tidak ada."

#: includes/class-post-manager.php:262
msgid "You cannot edit this post."
msgstr "Anda tidak dapat mengedit posting ini."

#: includes/class-post-manager.php:298
#. translators: %s: status slug
#, php-format
msgid "Status \"%s\" is not allowed."
msgstr "Status \"%s\" tidak diizinkan."

#: includes/class-post-manager.php:486
msgid "Each block requires a \"name\"."
msgstr "Setiap blok memerlukan \"nama\"."

#: includes/class-post-manager.php:522
#: includes/class-post-manager.php:530
msgid "Status \"future\" requires a \"date\" set in the future."
msgstr "Status \"future\" memerlukan \"tanggal\" yang diatur di masa depan."

#: includes/class-post-manager.php:594
msgid "A post cannot be its own parent."
msgstr "Sebuah posting tidak dapat menjadi induknya sendiri."

#: includes/class-post-manager.php:600
#. translators: 1: parent ID, 2: post type slug
#, php-format
msgid "Parent post %1$d does not exist or is not of type \"%2$s\"."
msgstr "Posting induk %1$d tidak ada atau bukan tipe \"%2$s\"."

#: includes/class-post-manager.php:635
#: includes/class-term-manager.php:34
#. translators: %s: taxonomy slug
#, php-format
msgid "Taxonomy \"%s\" does not exist."
msgstr "Taksonomi \"%s\" tidak ada."

#: includes/class-post-manager.php:643
#. translators: 1: taxonomy slug, 2: post type slug
#, php-format
msgid "Taxonomy \"%1$s\" is not registered for post type \"%2$s\"."
msgstr "Taksonomi \"%1$s\" tidak terdaftar untuk tipe posting \"%2$s\"."

#: includes/class-post-manager.php:656
#. translators: 1: term ID, 2: taxonomy slug
#, php-format
msgid "Term %1$d does not exist in taxonomy \"%2$s\"."
msgstr "Istilah %1$d tidak ada dalam taksonomi \"%2$s\"."

#: includes/class-rest-controller.php:777
msgid "You do not have permission to access this endpoint."
msgstr "Anda tidak memiliki izin untuk mengakses endpoint ini."

#: includes/class-rest-controller.php:794
msgid "You do not have permission to edit posts."
msgstr "Anda tidak memiliki izin untuk mengedit posting."

#: includes/class-rest-controller.php:811
msgid "You do not have permission to upload files."
msgstr "Anda tidak memiliki izin untuk mengunggah file."

#: includes/class-rest-controller.php:937
msgid "An unexpected error occurred."
msgstr "Terjadi kesalahan tak terduga."

#: includes/class-rest-controller.php:1046
msgid "Pattern not found."
msgstr "Pola tidak ditemukan."

#: includes/class-rest-controller.php:1132
msgid "No post found for this URL."
msgstr "Tidak ada posting yang ditemukan untuk URL ini."

#: includes/class-rest-controller.php:1276
msgid "Provide one of: post_id, url, or slug."
msgstr "Berikan salah satu dari: post_id, url, atau slug."

#: includes/class-rest-controller.php:1284
msgid "No post matched the lookup."
msgstr "Tidak ada posting yang cocok dengan pencarian."

#: includes/class-rest-controller.php:1597
#: includes/class-rest-controller.php:1671
msgid "At least one of \"attributes\" or \"innerHTML\" must be provided."
msgstr ""
"Setidaknya salah satu dari \"attributes\" atau \"innerHTML\" harus "
"disediakan."

#: includes/class-rest-controller.php:1738
#: includes/class-rest-controller.php:1852
msgid "The \"blocks\" parameter is required and must be a non-empty array."
msgstr "Parameter \"blocks\" diperlukan dan harus berupa array yang tidak kosong."

#: includes/class-rest-controller.php:1790
msgid ""
"The \"blocks\" parameter is required and must be an array (may be empty for "
"a pure delete)."
msgstr ""
"Parameter \"blocks\" diperlukan dan harus berupa array (bisa kosong untuk "
"penghapusan murni)."

#: includes/class-rest-controller.php:1950
msgid "Either \"path\" or \"ref\" is required."
msgstr "Salah satu dari \"path\" atau \"ref\" diperlukan."

#: includes/class-rest-controller.php:2066
#. translators: 1: post type label, 2: required capability
#, php-format
msgid "You do not have permission to edit this %1$s. Required capability: %2$s."
msgstr ""
"Anda tidak memiliki izin untuk mengedit %1$s ini. Kemampuan yang "
"diperlukan: %2$s."

#: includes/class-settings-page.php:67
#: includes/class-settings-page.php:68
msgid "Block MCP"
msgstr "Blok MCP"

#: includes/class-settings-page.php:241
#: includes/class-settings-page.php:265
msgid "You do not have permission to do this."
msgstr "Anda tidak memiliki izin untuk melakukan ini."

#: includes/class-settings-page.php:302
msgid "You do not have permission to view this page."
msgstr "Anda tidak memiliki izin untuk melihat halaman ini."

#: includes/class-settings-page.php:341
msgid "Block MCP Settings"
msgstr "Pengaturan Blok MCP"

#: includes/class-settings-page.php:348
#. translators: 1: total unique blocks, 2: dual-storage count
#, php-format
msgid ""
"Storage-mode scan complete. %1$d unique blocks classified (%2$d "
"dual-storage)."
msgstr ""
"Pemeriksaan mode penyimpanan selesai. %1$d blok unik diklasifikasikan (%2$d "
"penyimpanan ganda)."

#: includes/class-settings-page.php:356
msgid "Settings reset to defaults."
msgstr "Pengaturan direset ke pengaturan default."

#: includes/class-settings-page.php:359
msgid ""
"These settings drive how the Block MCP server classifies blocks (preferred "
"/ acceptable / avoid / legacy), suggests replacements, and detects "
"dual-storage blocks that need both attributes and innerHTML on every update."
msgstr ""
"Pengaturan ini mengatur bagaimana server Block MCP mengklasifikasikan blok "
"(preferensi / dapat diterima / hindari / warisan), menyarankan pengganti, "
"dan mendeteksi blok penyimpanan ganda yang membutuhkan atribut dan "
"innerHTML pada setiap pembaruan."

#: includes/class-settings-page.php:389
msgid "Namespace tier scores"
msgstr "Skor tingkat namespace"

#: includes/class-settings-page.php:390
msgid ""
"Score 0–100 per namespace. >= 80 = preferred, >= 50 = acceptable, >= 10 = "
"avoid (warning), < 10 = legacy (hard reject on insert)."
msgstr ""
"Skor 0–100 per namespace. >= 80 = preferensi, >= 50 = dapat diterima, >= 10 "
"= hindari (peringatan), < 10 = warisan (penolakan keras saat penyisipan)."

