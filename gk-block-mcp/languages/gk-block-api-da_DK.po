msgstr "Se ressourcen block-mcp://agent-guide for den komplette tillad/bloker-liste."

#: includes/class-block-crud.php:1725
#, php-format
msgid "%s blocks are deprecated on this site."
msgstr "%s blokke er forældede på denne side."

#: includes/class-block-crud.php:1829
