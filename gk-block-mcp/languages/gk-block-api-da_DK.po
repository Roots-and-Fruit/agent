msgstr "Namespace-lagscores"

#: includes/class-settings-page.php:390
msgid ""
"Score 0–100 per namespace. >= 80 = preferred, >= 50 = acceptable, >= 10 = "
"avoid (warning), < 10 = legacy (hard reject on insert)."
msgstr ""
"Score 0–100 per namespace. >= 80 = foretrukket, >= 50 = acceptabel, >= 10 = "
"undgå (advarsel), < 10 = ældre (hård afvisning ved indsættelse)."

