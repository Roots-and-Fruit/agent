msgstr "Namnområdesnivåpoäng"

#: includes/class-settings-page.php:390
msgid ""
"Score 0–100 per namespace. >= 80 = preferred, >= 50 = acceptable, >= 10 = "
"avoid (warning), < 10 = legacy (hard reject on insert)."
msgstr ""
"Poäng 0–100 per namnrum. >= 80 = föredraget, >= 50 = acceptabelt, >= 10 = "
"undvik (varning), < 10 = äldre (hård avvisning vid insättning)."

