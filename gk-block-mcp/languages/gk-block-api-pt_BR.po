msgstr ""
"Consulte o recurso block-mcp://agent-guide para a lista completa de "
"permitir/negociar."

#: includes/class-block-crud.php:1725
#, php-format
msgid "%s blocks are deprecated on this site."
msgstr "Blocos %s estão obsoletos neste site."

#: includes/class-block-crud.php:1829
