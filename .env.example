# Roots and Fruit AS — environment variables
# groot and groot-mapper MCPs require no secrets.

# Optional MCPs (enable in groot.config.json + .cursor/mcp.json when needed)

# google-analytics MCP
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# drip MCP
# DRIP_API_KEY=your-drip-api-key
# DRIP_ACCOUNT_ID=your-drip-account-id

# dataforseo MCP
# DATAFORSEO_USERNAME=your-dataforseo-username
# DATAFORSEO_PASSWORD=your-dataforseo-password

# helpscout MCP
# HELPSCOUT_APP_ID=your-helpscout-app-id
# HELPSCOUT_APP_SECRET=your-helpscout-app-secret
# HELPSCOUT_DOCS_API_KEY=your-helpscout-docs-api-key

# wordpress-rootsandfruit MCP (@automattic/mcp-wordpress-remote via run-wordpress-mcp.mjs)
# Run from agent/ repo root:
#   .\tools\scripts\audit-mcp-abilities.ps1 -ExpectBlocks
#   .\tools\scripts\test-wordpress-mcp-http.ps1 -ExpectRfAbilities -ExpectBlocks

ROOTSANDFRUIT_MCP_URL=https://rootsandfruit.com/wp-json/mcp/mcp-adapter-default-server
ROOTSANDFRUIT_MCP_USERNAME=your-wp-username
ROOTSANDFRUIT_MCP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
