# Roots and Fruit AS — environment variables

ROOTSANDFRUIT_MCP_URL=https://rootsandfruit.com/wp-json/mcp/mcp-adapter-default-server
ROOTSANDFRUIT_MCP_USERNAME=your-wp-username
ROOTSANDFRUIT_MCP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# GravityKit Block MCP (optional second Cursor MCP — @gravitykit/block-mcp)
BLOCK_MCP_WORDPRESS_URL=https://rootsandfruit.com
BLOCK_MCP_USERNAME=block-mcp
BLOCK_MCP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# DataforSEO MCP (article keyword research)
DATAFORSEO_USERNAME=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-api-password

# Plausible MCP (site analytics in Cursor)
PLAUSIBLE_API_KEY=your-plausible-api-key
PLAUSIBLE_SITE_ID=rootsandfruit.com
# PLAUSIBLE_BASE_URL=https://plausible.io

# Google Search Console MCP — auth is gcloud login on this machine (see agent_docs/analytics-mcp.md)
GSC_SITE_URL=https://rootsandfruit.com/
# GSC_OUTPUT_FORMAT=toon
